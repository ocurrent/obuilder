(rule
 (target sandbox.detected.ml)
 (enabled_if
  (= %{os_type} Win32))
 (action
  (copy# sandbox.docker.ml %{target})))

(rule
 (target sandbox.detected.ml)
 (enabled_if
  (<> %{os_type} Win32))
 (action
  (copy# sandbox.runc.ml %{target})))

(rule
 (target sandbox.ml)
 (mode fallback)
 (action
  (copy sandbox.detected.ml %{target})))

